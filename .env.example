# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase public client, safe for browser use.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server-only admin client. Never expose this through NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=

# AI server provider. Use mock for local demo without paid/API access.
AI_PROVIDER=mock
OPENAI_API_KEY=
AI_TEXT_MODEL=gpt-4.1-mini
AI_IMAGE_MODEL=gpt-image-1

# Storage and database helpers
SIGNED_URL_TTL_SECONDS=3600
DATABASE_URL=
