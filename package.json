{
  "name": "exchange-life",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "next build --webpack",
    "dev": "next dev",
    "typecheck": "tsc --noEmit --pretty false",
    "test": "node scripts/smoke-test.mjs",
    "start": "next start",
    "lint": "eslint .",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
